arr = [4, -2, 5, -7, 0, 8]

positive = 0
negative = 0
zero = 0

for i in range(len(arr)):
    if arr[i] > 0:
        positive = positive + 1
    elif arr[i] < 0:
        negative = negative + 1
    else:
        zero = zero + 1

print("Positive =", positive)
print("Negative =", negative)
print("Zero =", zero)
